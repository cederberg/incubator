#!/usr/bin/env python3
"""List and inspect Codex sessions.

Usage:
  codex-sessions                                    List sessions in current directory
  codex-sessions --list-dirs                        List all project directories with sessions
  codex-sessions -d ~/Projects/myapp                Filter by a specific directory
  codex-sessions <session-id>               Session summary (tokens, tools, turns)
  codex-sessions <session-id> --raw         Full transcript with reasoning and tool I/O
  codex-sessions <session-id> --turn 4      Transcript for a single turn (implies --raw)
  codex-sessions <session-id> --turn 4-10   Transcript for a range of turns

Session IDs use UUID format. Accepts a prefix, full ID, or rollout .jsonl path.
Data is stored in ~/.codex/state_5.sqlite and ~/.codex/sessions/**/rollout-*.jsonl.
"""

import argparse
import json
import re
import sqlite3
import sys
from collections import Counter
from datetime import datetime, timedelta, timezone
from pathlib import Path
from typing import Optional

DATA_DIR = Path.home() / ".codex"
DB_PATH = DATA_DIR / "state_5.sqlite"
DEFAULT_COUNT = 30
W = 120

IGNORE_PROMPTS = (
    re.compile(r"^/(clear|new)\s*", re.I),
    re.compile(r"^/(model|help|usage|exit|quit|context|status)\b.*", re.I | re.DOTALL),
)


def _filter_prompt(text: str) -> Optional[str]:
    for pattern in IGNORE_PROMPTS:
        text = pattern.sub("", text, count=1).strip()
    return text or None


def truncate(text: str, width: int) -> str:
    text = text.replace("\n", " ").strip()
    if len(text) <= width:
        return text
    suffix = f" ...({len(text)} chars)"
    return text[: width - len(suffix)] + suffix


def parse_ts(ms: int | str) -> datetime:
    if isinstance(ms, str):
        return datetime.fromisoformat(ms.replace("Z", "+00:00"))
    if ms > 10_000_000_000:
        return datetime.fromtimestamp(ms / 1000, tz=timezone.utc)
    return datetime.fromtimestamp(ms, tz=timezone.utc)


def format_time(ms: int | str) -> str:
    try:
        return parse_ts(ms).astimezone().strftime("%Y-%m-%d %H:%M")
    except Exception:
        return str(ms)[:16]


def format_hhmm(ms: int | str) -> str:
    try:
        return parse_ts(ms).astimezone().strftime("%H:%M")
    except Exception:
        return "??:??"


def format_duration(td: timedelta) -> str:
    td = timedelta(seconds=round(td.total_seconds()))
    return str(td).removeprefix("0:")


def format_separator(label: str, char: str = "-", width: int = W) -> str:
    return label + char * max(0, width - len(label))


def format_dir(path: str) -> str:
    return path.replace(str(Path.home()), "~") if path else "-"


def format_usd(v: float) -> str:
    return f"${v:.4f}" if v else "-"


def format_any(v: object) -> str:
    if v is None:
        return "?"
    if isinstance(v, timedelta):
        return format_duration(v)
    if isinstance(v, int):
        return f"{v:,}"
    if isinstance(v, float):
        return f"{v:.4f}"
    s = str(v)
    return s if s != "-" else ""


def print_section(title: str) -> None:
    print(f"\n\n=== {title} ===\n")


def print_properties(props: list[tuple[str, str]]) -> None:
    key_w = max(len(k) for k, _ in props) + 2
    for key, val in props:
        print(f"{key:<{key_w}}{val}")


def print_table(rows: list[list[object]]) -> None:
    ncols = len(rows[0])
    row_strs = [[format_any(c) for c in r] for r in rows]
    col_data = [[r[c] for r in rows[1:]] for c in range(ncols)]
    aligns = [">" if data and all(_is_num(v) for v in data) else "<" for data in col_data]
    widths = [max(len(s[c]) for s in row_strs) for c in range(ncols)]
    total = sum(widths) + 2 * (ncols - 1)
    if total > W:
        widths[-1] = max(1, widths[-1] - (total - W))
    for i, r in enumerate(row_strs):
        cells = [f"{truncate(s, widths[c]):{aligns[c]}{widths[c]}}" for c, s in enumerate(r)]
        print("  ".join(cells))
        if i == 0:
            print("-" * (sum(widths) + 2 * (ncols - 1)))


def _is_num(v: object) -> bool:
    if v is None:
        return True
    if isinstance(v, (int, float, timedelta)):
        return True
    return isinstance(v, str) and bool(v) and v[0] == "$"


def _fmt_args(name: str, args: dict) -> str:
    if not args:
        return ""
    for key in ("path", "filePath", "cmd", "command", "pattern", "query", "prompt", "intent", "description"):
        if key in args and len(args) == 1:
            return str(args[key])
    return json.dumps(args, ensure_ascii=False)


def get_conn() -> sqlite3.Connection:
    if not DB_PATH.exists():
        print(f"Database not found: {DB_PATH}", file=sys.stderr)
        print("Codex stores session metadata in ~/.codex/state_5.sqlite", file=sys.stderr)
        sys.exit(1)
    conn = sqlite3.connect(str(DB_PATH))
    conn.row_factory = sqlite3.Row
    return conn


def resolve_session(conn: sqlite3.Connection, session_id: str) -> str:
    """Resolve a partial session ID or rollout path to a full session ID."""
    candidate = Path(session_id).expanduser()
    if candidate.is_file():
        row = conn.execute("SELECT id FROM threads WHERE rollout_path = ?", (str(candidate),)).fetchone()
        if row:
            return row["id"]
        file_id = _id_from_rollout_path(candidate)
        if file_id:
            return file_id

    rows = conn.execute("""
        SELECT id FROM threads
        WHERE id = ? OR id LIKE ?
        ORDER BY created_at_ms DESC, created_at DESC
    """, (session_id, f"{session_id}%")).fetchall()
    if len(rows) == 0:
        print(f"Session not found: {session_id}", file=sys.stderr)
        sys.exit(1)
    if len(rows) > 1:
        print(f"Ambiguous session '{session_id}' - matches:", file=sys.stderr)
        for r in rows:
            print(f"  {r['id']}", file=sys.stderr)
        sys.exit(1)
    return rows[0]["id"]


def load_all_summaries(conn: sqlite3.Connection) -> list[dict]:
    rows = conn.execute("""
        SELECT id, cwd, title, created_at, updated_at, created_at_ms, updated_at_ms,
               first_user_message, rollout_path
        FROM threads
        WHERE archived = 0
        ORDER BY created_at_ms DESC, created_at DESC
    """).fetchall()

    summaries = []
    for r in rows:
        first_text = _filter_prompt((r["first_user_message"] or "").strip())
        rollout_path = Path(r["rollout_path"])
        turn_count = _count_user_turns(rollout_path) if rollout_path.exists() else 0

        summaries.append({
            "id": r["id"],
            "slug": "",
            "start_time": r["created_at_ms"] or r["created_at"],
            "end_time": r["updated_at_ms"] or r["updated_at"],
            "cwd": r["cwd"] or "",
            "first_prompt": first_text or "(no prompt found)",
            "turn_count": turn_count,
        })
    return summaries


def parse_session_detail(conn: sqlite3.Connection, session_id: str) -> Optional[dict]:
    srow = conn.execute("""
        SELECT id, cwd, title, created_at, updated_at, created_at_ms, updated_at_ms,
               model, agent_role, rollout_path, tokens_used
        FROM threads WHERE id = ?
    """, (session_id,)).fetchone()
    if not srow:
        return None

    start_time = srow["created_at_ms"] or srow["created_at"]
    end_time = srow["updated_at_ms"] or srow["updated_at"]
    duration = parse_ts(end_time) - parse_ts(start_time) if end_time and start_time else timedelta(0)
    cwd = srow["cwd"] or ""
    model_id = srow["model"] or ""
    rollout_path = Path(srow["rollout_path"])

    tool_calls: dict[str, int] = {}
    tool_errors: dict[str, int] = {}
    user_messages: list[dict] = []
    transcript: list[dict] = []
    current_turn = 0
    usage_by_model: dict[str, dict[str, int | float]] = {}
    turn_response_ms: dict[int, int] = {}
    pending_tool_names: dict[str, str] = {}
    last_user_ts: str | None = None

    for event in _load_rollout_events(rollout_path):
        ts = event.get("timestamp")
        payload = event.get("payload")
        if not isinstance(payload, dict):
            continue

        if event.get("type") == "session_meta":
            meta_model = payload.get("model") or payload.get("model_provider")
            if meta_model and not model_id:
                model_id = str(meta_model)
            continue

        ptype = payload.get("type")
        if ptype == "message":
            role = payload.get("role", "")
            text = _message_text(payload)

            if role == "user":
                text = _clean_user_text(text)
                if text:
                    current_turn += 1
                    user_messages.append({"text": text, "ts": ts})
                    transcript.append({"kind": "user", "turn": current_turn, "text": text, "ts": ts})
                    if last_user_ts:
                        try:
                            prev = len(user_messages) - 1
                            turn_response_ms[prev] = int((parse_ts(ts) - parse_ts(last_user_ts)).total_seconds() * 1000)
                        except Exception:
                            pass
                    last_user_ts = ts

            elif role == "assistant":
                if text:
                    transcript.append({"kind": "assistant", "turn": current_turn, "text": text})

        elif ptype == "reasoning":
            text = _reasoning_text(payload)
            if text:
                transcript.append({"kind": "thinking", "turn": current_turn, "text": text})

        elif ptype == "function_call":
            name = payload.get("name", "?")
            args = _json_obj(payload.get("arguments")) or {}
            call_id = payload.get("call_id", "")
            tool_calls[name] = tool_calls.get(name, 0) + 1
            pending_tool_names[call_id] = name
            transcript.append({
                "kind": "tool_call", "turn": current_turn,
                "name": name, "args": args, "call_id": call_id,
            })

        elif ptype == "function_call_output":
            call_id = payload.get("call_id", "")
            name = pending_tool_names.get(call_id, "?")
            out = payload.get("output", "")
            is_error = _is_tool_output_error(out)
            if is_error:
                tool_errors[name] = tool_errors.get(name, 0) + 1
            transcript.append({
                "kind": "tool_result", "turn": current_turn,
                "call_id": call_id, "name": name,
                "content": out, "success": not is_error,
            })

        elif ptype == "token_count":
            info = payload.get("info", {})
            if isinstance(info, dict):
                usage = info.get("last_token_usage") or {}
                if isinstance(usage, dict) and usage:
                    mid_key = model_id or "unknown"
                    bucket = usage_by_model.setdefault(mid_key, {"cost": 0.0})
                    bucket["input"] = bucket.get("input", 0) + int(usage.get("input_tokens", 0) or 0)
                    bucket["output"] = bucket.get("output", 0) + int(usage.get("output_tokens", 0) or 0)
                    bucket["reasoning"] = bucket.get("reasoning", 0) + int(usage.get("reasoning_output_tokens", 0) or 0)
                    bucket["total"] = bucket.get("total", 0) + int(usage.get("total_tokens", 0) or 0)
                    bucket["cache_read"] = bucket.get("cache_read", 0) + int(usage.get("cached_input_tokens", 0) or 0)

    turns = []
    for i, m in enumerate(user_messages):
        resp_ms = turn_response_ms.get(i + 1)
        turns.append({"text": m["text"], "ts": m["ts"], "resp_ms": resp_ms})

    return {
        "id": srow["id"],
        "slug": "",
        "title": srow["title"] or "",
        "start_time": start_time,
        "end_time": end_time,
        "duration": duration,
        "cwd": cwd,
        "agent": srow["agent_role"] or "",
        "model_id": model_id,
        "turns": turns,
        "user_turn_count": len(turns),
        "tool_calls": tool_calls,
        "tool_errors": tool_errors,
        "usage_by_model": usage_by_model,
        "transcript": transcript,
    }


def cmd_dirs(count: int) -> None:
    conn = get_conn()
    rows = conn.execute("SELECT cwd FROM threads WHERE archived = 0").fetchall()
    conn.close()

    home = str(Path.home())
    tally: Counter = Counter()
    for r in rows:
        tally[r["cwd"] or "(unknown)"] += 1
    if not tally:
        print("No sessions found.")
        return
    dirs = sorted(tally.keys(), key=lambda d: tally[d], reverse=True)[:count]
    print_table([["Sessions", "Directory"]] + [
        [tally[d], d.replace(home, "~")] for d in dirs
    ])


def cmd_list(count: int, dir_filter: Optional[str]) -> None:
    filter_path = str(Path(dir_filter).expanduser().resolve()) if dir_filter else None
    conn = get_conn()
    summaries = load_all_summaries(conn)
    conn.close()

    if filter_path:
        summaries = [s for s in summaries if s["cwd"].startswith(filter_path)]
    summaries.sort(key=lambda s: s["start_time"], reverse=True)
    summaries = summaries[:count]

    if not summaries:
        msg = "No sessions found."
        if filter_path:
            msg += f" (filter: {filter_path})"
        print(msg)
        return

    home = str(Path.home())
    dir_display = (filter_path or str(Path.cwd())).replace(home, "~")
    print(f"Directory: {dir_display}\n")

    print_table([["Session", "Started", "Turns", "First prompt"]] + [
        [s["id"][:12], format_time(s["start_time"]), s["turn_count"], s["first_prompt"]]
        for s in summaries
    ])


def parse_turn_filter(spec: str) -> set[int]:
    result = set()
    for part in spec.split(","):
        part = part.strip()
        if "-" in part:
            lo, hi = part.split("-", 1)
            result.update(range(int(lo), int(hi) + 1))
        else:
            result.add(int(part))
    return result


def format_turn_range(turn_filter: set[int]) -> str:
    return ", ".join(
        f"{min(g)}-{max(g)}" if len(g) > 1 else str(min(g))
        for g in [sorted(turn_filter)]
    )


def render_transcript(transcript: list[dict], turn_filter: Optional[set] = None) -> None:
    TW = 72
    pending_calls: dict[str, dict] = {}

    for item in transcript:
        if turn_filter is not None and item.get("turn") not in turn_filter:
            continue
        kind = item["kind"]

        if kind == "user":
            print()
            print("=" * TW)
            print(f"  TURN {item['turn']}  {format_hhmm(item['ts'])}")
            print("=" * TW)
            print(item["text"])

        elif kind == "thinking":
            print()
            print(format_separator("-- thinking ", "-", TW))
            print(item["text"])

        elif kind == "assistant":
            print()
            print(format_separator("-- assistant ", "-", TW))
            print(item["text"])

        elif kind == "tool_call":
            name = item["name"]
            args = item["args"]
            call_id = item["call_id"]
            pending_calls[call_id] = item
            print()
            print(format_separator(f"-- {name} ", "-", TW))
            arg_str = _fmt_args(name, args)
            if arg_str:
                print(arg_str)

        elif kind == "tool_result":
            call_id = item["call_id"]
            content = item["content"] or ""
            success = item["success"]
            name = item["name"]
            pending_calls.pop(call_id, None)
            limit = 1200
            flag = " [ERROR]" if not success else ""
            print(f"-> {name}{flag}")
            if len(content) > limit:
                print(content[:limit])
                print(f"  ... ({len(content) - limit:,} more chars)")
            else:
                print(content)
            print()


def cmd_detail(session_id: str, raw: bool = False, turn_filter: Optional[set] = None) -> None:
    conn = get_conn()
    full_id = resolve_session(conn, session_id)

    d = parse_session_detail(conn, full_id)
    conn.close()
    if d is None:
        print(f"Could not parse session: {session_id}", file=sys.stderr)
        sys.exit(1)

    cwd = d.get("cwd", "")

    print_properties([
        ("Session:", d["id"]),
        ("Title:", d.get("title") or "-"),
        ("Started:", format_time(d["start_time"])),
        ("Ended:", format_time(d["end_time"]) if d.get("end_time") else "-"),
        ("Duration:", format_duration(d["duration"])),
        ("Directory:", format_dir(cwd)),
        ("Agent:", d.get("agent") or "-"),
        ("Model:", d.get("model_id") or "-"),
        ("Turns:", str(d["user_turn_count"])),
        ("Tool calls:", str(sum(d["tool_calls"].values()))),
    ])

    ubm = d["usage_by_model"]
    if ubm:
        print_section("Tokens")
        print_table([
            ["Model", "Input", "Output", "Cached", "Cost"]
        ] + [
            [m, u.get("input", 0), u.get("output", 0), u.get("cache_read", 0), format_usd(u.get("cost"))]
            for m, u in ubm.items()
        ])

    tc = d["tool_calls"]
    if tc:
        print_section("Tool usage")
        print_table([
            ["Tool Name", "Calls", "Errors"]
        ] + [
            [name, tc[name], d["tool_errors"].get(name, 0) or ""]
            for name in sorted(tc, key=lambda n: -tc[n])
        ])

    turns = d["turns"]
    if turns:
        print_section(f"Turns ({len(turns)})")
        print_table([["#", "Start", "Time", "Message"]] + [
            [i, format_hhmm(t["ts"]),
             timedelta(milliseconds=t["resp_ms"]) if t["resp_ms"] else None,
             t["text"]]
            for i, t in enumerate(turns, 1)
        ])

    if raw:
        if turn_filter:
            print_section(f"Transcript  (turns {format_turn_range(turn_filter)})")
        else:
            print_section("Transcript")
        render_transcript(d["transcript"], turn_filter=turn_filter)


def _id_from_rollout_path(path: Path) -> Optional[str]:
    match = re.search(r"rollout-.*-([0-9a-f]{8}-[0-9a-f-]{27})\.jsonl$", path.name)
    return match.group(1) if match else None


def _load_rollout_events(path: Path):
    if not path.exists():
        return
    try:
        with path.open(encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if line:
                    try:
                        yield json.loads(line)
                    except json.JSONDecodeError:
                        continue
    except OSError:
        return


def _count_user_turns(path: Path) -> int:
    count = 0
    for event in _load_rollout_events(path):
        payload = event.get("payload")
        if not isinstance(payload, dict) or payload.get("type") != "message":
            continue
        if payload.get("role") == "user" and _clean_user_text(_message_text(payload)):
            count += 1
    return count


def _message_text(payload: dict) -> str:
    parts = payload.get("content", [])
    if isinstance(parts, str):
        return parts
    if not isinstance(parts, list):
        return ""
    texts = []
    for part in parts:
        if isinstance(part, dict):
            text = part.get("text") or part.get("input_text") or part.get("output_text")
            if isinstance(text, str):
                texts.append(text)
    return "\n".join(texts).strip()


def _clean_user_text(text: str) -> Optional[str]:
    text = text.strip()
    if text.startswith("# AGENTS.md instructions for "):
        return None
    if text.startswith("<environment_context>"):
        return None
    if text.startswith("<skill>"):
        return None
    return _filter_prompt(text) if text else None


def _reasoning_text(payload: dict) -> str:
    parts = []
    content = payload.get("content")
    if isinstance(content, str):
        parts.append(content)
    if isinstance(content, list):
        parts.extend(p.get("text", "") for p in content if isinstance(p, dict))
    summary = payload.get("summary")
    if isinstance(summary, list):
        parts.extend(p.get("text", "") for p in summary if isinstance(p, dict))
    return "\n".join(p for p in parts if p).strip()


def _json_obj(text: object) -> Optional[dict]:
    if isinstance(text, dict):
        return text
    if not isinstance(text, str) or not text:
        return None
    try:
        value = json.loads(text)
    except json.JSONDecodeError:
        return None
    return value if isinstance(value, dict) else None


def _is_tool_output_error(output: object) -> bool:
    if not isinstance(output, str):
        return False
    match = re.search(r"Process exited with code (\d+)", output)
    if match:
        return match.group(1) != "0"
    return "Traceback (most recent call last):" in output or "SyntaxError:" in output


def main():
    parser = argparse.ArgumentParser(
        description="List and inspect Codex sessions.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            "  codex-sessions                         List sessions in current directory\n"
            "  codex-sessions --list-dirs             List all project directories with sessions\n"
            "  codex-sessions -d ~/Projects/myapp     Filter by a specific directory\n"
            "  codex-sessions 019e4685                Show detail for a session (ID prefix)\n"
            "  codex-sessions 019e4685 --raw          Full transcript with tool output\n"
        ),
    )
    parser.add_argument("session_id", nargs="?", help="Session ID (prefix or full UUID)")
    parser.add_argument("-n", "--count", type=int, default=DEFAULT_COUNT, metavar="N",
                        help=f"Number of sessions to list (default: {DEFAULT_COUNT})")
    parser.add_argument("-d", "--dir", metavar="DIR",
                        help="Filter sessions by working directory (default: current directory)")
    parser.add_argument("--list-dirs", action="store_true",
                        help="List all project directories with sessions")
    parser.add_argument("--raw", action="store_true",
                        help="Show full transcript with reasoning (use with a session ID)")
    parser.add_argument("--turn", metavar="RANGE",
                        help="Filter transcript to specific turns, e.g. 4 or 4-10 or 4,7-10 (implies --raw)")

    args = parser.parse_args()

    if args.session_id:
        turn_filter = parse_turn_filter(args.turn) if args.turn else None
        cmd_detail(args.session_id, raw=args.raw or turn_filter is not None,
                   turn_filter=turn_filter)
    elif args.list_dirs:
        cmd_dirs(args.count)
    else:
        dir_filter = args.dir if args.dir else str(Path.cwd())
        cmd_list(args.count, dir_filter)


if __name__ == "__main__":
    main()
