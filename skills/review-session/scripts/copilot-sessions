#!/usr/bin/env python3
"""List and inspect Copilot sessions.

Usage:
  copilot-sessions                           List sessions in current directory
  copilot-sessions --list-dirs               List all project directories with sessions
  copilot-sessions -d ~/Projects/myapp       Filter by a specific directory
  copilot-sessions <session-id>              Session summary (id, tokens, tools, sub-agents, turns)
  copilot-sessions <session-id> --raw        Full transcript with reasoning and tool I/O
  copilot-sessions <session-id> --turn 4     Transcript for a single turn (implies --raw)
  copilot-sessions <session-id> --turn 4-10  Transcript for a range of turns

Session IDs can be given as a full UUID, an 8-char prefix, or a path to a session directory.
"""

import argparse
import json
import re
import sys
from collections import Counter, defaultdict
from datetime import datetime, timedelta
from pathlib import Path
from typing import Optional

DATA_DIR = Path.home() / ".copilot" / "session-state"
DEFAULT_COUNT = 30
MAX_PROMPT_WIDTH = 80
W = 120

IGNORE_PROMPTS = (
    re.compile(r"^/(clear|new)\s*", re.I),
    re.compile(r"^/(model|help|usage|exit|quit|context|status)\b.*", re.I | re.DOTALL),
)


def _filter_prompt(text: str) -> Optional[str]:
    for pattern in IGNORE_PROMPTS:
        text = pattern.sub("", text, count=1).strip()
    return text or None


def truncate(text: str, width: int) -> str:
    text = text.replace("\n", " ").strip()
    if len(text) <= width:
        return text
    suffix = f" ...({len(text)} chars)"
    return text[: width - len(suffix)] + suffix


def parse_iso(ts: str) -> datetime:
    return datetime.fromisoformat(ts.replace("Z", "+00:00"))


def format_time(ts: str) -> str:
    try:
        return parse_iso(ts).astimezone().strftime("%Y-%m-%d %H:%M")
    except Exception:
        return ts[:16]


def format_hhmm(ts: str) -> str:
    try:
        return parse_iso(ts).astimezone().strftime("%H:%M")
    except Exception:
        return ts[11:16]


def format_duration(td: timedelta) -> str:
    total = int(td.total_seconds())
    h, rem = divmod(total, 3600)
    m, s = divmod(rem, 60)
    if h:
        return f"{h}h {m}m"
    if m:
        return f"{m}m {s}s"
    return f"{s}s"


def load_events(session_dir: Path) -> Optional[list]:
    events_file = session_dir / "events.jsonl"
    if not events_file.exists():
        return None
    events = []
    try:
        with events_file.open() as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    events.append(json.loads(line))
                except json.JSONDecodeError:
                    continue
    except OSError:
        return None
    return events


def parse_session_summary(session_dir: Path) -> Optional[dict]:
    events_file = session_dir / "events.jsonl"
    if not events_file.exists():
        return None

    start_time = None
    end_time = None
    first_prompt = None
    cwd = None
    git_branch = None
    turn_count = 0

    try:
        with events_file.open() as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    event = json.loads(line)
                except json.JSONDecodeError:
                    continue

                t = event.get("type", "")
                ts = event.get("timestamp")
                if ts:
                    end_time = ts
                if t == "session.start":
                    data = event.get("data", {})
                    start_time = ts or data.get("startTime")
                    ctx = data.get("context", {})
                    cwd = ctx.get("cwd", "")
                    git_branch = ctx.get("branch", "")
                elif t == "user.message":
                    content = event.get("data", {}).get("content", "")
                    if content:
                        turn_count += 1
                        if first_prompt is None:
                            first_prompt = _filter_prompt(content)
    except OSError:
        return None

    if not start_time:
        return None

    return {
        "id": session_dir.name,
        "start_time": start_time,
        "end_time": end_time,
        "cwd": cwd or "",
        "git_branch": git_branch or "",
        "first_prompt": first_prompt or "(no prompt found)",
        "turn_count": turn_count,
    }



def parse_session_detail(session_dir: Path) -> Optional[dict]:
    events = load_events(session_dir)
    if events is None:
        return None

    start_time = None
    end_time = None
    cwd = None
    branch = None
    first_prompt = None
    user_messages = []
    event_counts = {}

    # Tool tracking
    tool_call_info: dict[str, dict] = {}   # toolCallId -> {name, args, intention}
    tool_calls: dict[str, int] = {}  # tool_name -> call count
    tool_errors: dict[str, int] = {} # tool_name -> error count

    # Subagent tracking
    subagent_list: list[dict] = []
    subagent_by_callid: dict[str, int] = {}

    # Model metrics (from session.shutdown)
    model_metrics: Optional[dict] = None

    # Extra session fields
    reasoning_effort: Optional[str] = None
    code_changes: Optional[dict] = None
    model: Optional[str] = None

    # Transcript items for --raw
    transcript: list[dict] = []
    current_turn: int = 0

    for event in events:
        t = event.get("type", "")
        ts = event.get("timestamp", "")
        event_counts[t] = event_counts.get(t, 0) + 1

        if t == "session.start":
            data = event.get("data", {})
            start_time = ts or data.get("startTime")
            ctx = data.get("context", {})
            cwd = ctx.get("cwd", "")
            branch = ctx.get("branch", "")
            reasoning_effort = data.get("reasoningEffort")

        elif t == "user.message":
            content = event.get("data", {}).get("content", "")
            if content:
                user_messages.append({"text": content, "ts": ts})
                if first_prompt is None:
                    first_prompt = content
                current_turn += 1
                transcript.append({"kind": "user", "turn": current_turn, "text": content, "ts": ts})

        elif t == "assistant.message":
            d = event.get("data", {})
            thinking = d.get("reasoningText", "").strip()
            text = d.get("content", "").strip()
            if thinking:
                transcript.append({"kind": "thinking", "turn": current_turn, "text": thinking})
            if text:
                transcript.append({"kind": "assistant", "turn": current_turn, "text": text})
            for tr in d.get("toolRequests", []):
                call_id = tr.get("toolCallId", "")
                name = tr.get("name", "?")
                args = tr.get("arguments", {})
                intention = tr.get("intentionSummary", "")
                tool_call_info[call_id] = {"name": name, "args": args, "intention": intention}
                tool_calls[name] = tool_calls.get(name, 0) + 1
                transcript.append({"kind": "tool_call", "turn": current_turn, "name": name,
                                    "args": args, "call_id": call_id, "intention": intention})

        elif t == "subagent.started":
            d = event.get("data", {})
            call_id = d.get("toolCallId", "")
            info = tool_call_info.get(call_id, {})
            args = info.get("args", {})
            idx = len(subagent_list)
            subagent_list.append({
                "call_id": call_id,
                "agent_type": d.get("agentName", ""),
                "display_name": d.get("agentDisplayName", ""),
                "task_name": args.get("name", ""),
                "mode": args.get("mode", "sync"),
                "prompt": args.get("prompt", ""),
                "result": None,
                "started_ts": ts,
                "completed_ts": None,
                "wall_ms": None,
                "turn": current_turn,
            })
            subagent_by_callid[call_id] = idx

        elif t == "subagent.completed":
            d = event.get("data", {})
            call_id = d.get("toolCallId", "")
            idx = subagent_by_callid.get(call_id)
            if idx is not None:
                subagent_list[idx]["completed_ts"] = ts
                try:
                    started = subagent_list[idx]["started_ts"]
                    subagent_list[idx]["wall_ms"] = int(
                        (parse_iso(ts) - parse_iso(started)).total_seconds() * 1000
                    )
                except Exception:
                    pass

        elif t == "tool.execution_complete":
            d = event.get("data", {})
            call_id = d.get("toolCallId", "")
            success = d.get("success", True)
            result = d.get("result", {})
            content = result.get("content", "") if isinstance(result, dict) else str(result)
            name = tool_call_info.get(call_id, {}).get("name", "?")
            if not success:
                tool_errors[name] = tool_errors.get(name, 0) + 1
            idx = subagent_by_callid.get(call_id)
            if idx is not None:
                subagent_list[idx]["result"] = content
            transcript.append({"kind": "tool_result", "turn": current_turn, "call_id": call_id,
                                "name": name, "content": content, "success": success})

        elif t == "session.shutdown":
            sd = event.get("data", {})
            model_metrics = sd.get("modelMetrics")
            code_changes = sd.get("codeChanges") or None
            model = sd.get("currentModel")

        if ts:
            end_time = ts

    if not start_time:
        return None

    try:
        duration = parse_iso(end_time) - parse_iso(start_time)
    except Exception:
        duration = timedelta(0)

    # Compute per-turn response times (wall time to next user message, or session end)
    turns = []
    for i, m in enumerate(user_messages):
        next_ts = user_messages[i + 1]["ts"] if i + 1 < len(user_messages) else end_time
        try:
            resp_ms = int((parse_iso(next_ts) - parse_iso(m["ts"])).total_seconds() * 1000)
        except Exception:
            resp_ms = None
        turns.append({"text": m["text"], "ts": m["ts"], "resp_ms": resp_ms})

    return {
        "id": session_dir.name,
        "start_time": start_time,
        "end_time": end_time,
        "duration": duration,
        "cwd": cwd,
        "git_branch": git_branch,
        "reasoning_effort": reasoning_effort,
        "model": model,
        "turns": turns,
        "user_turn_count": len(turns),
        "assistant_turn_count": event_counts.get("assistant.turn_end", 0),
        "subagents": subagent_list,
        "total_events": len(events),
        "event_counts": event_counts,
        "tool_calls": tool_calls,
        "tool_errors": tool_errors,
        "model_metrics": model_metrics,
        "code_changes": code_changes,
        "transcript": transcript,
    }


def ruled(label: str, char: str = "-", width: int = W) -> str:
    return label + char * max(0, width - len(label))


def section(title: str) -> None:
    print()
    print(ruled(f"-- {title} "))


def resolve_session_dir(session_id: str) -> Optional[Path]:
    candidate = Path(session_id).expanduser()
    if candidate.is_dir():
        return candidate
    if len(session_id) == 36 and (DATA_DIR / session_id).is_dir():
        return DATA_DIR / session_id
    # prefix search
    matches = [d for d in DATA_DIR.iterdir() if d.is_dir() and d.name.startswith(session_id)]
    if len(matches) == 1:
        return matches[0]
    if len(matches) > 1:
        print(f"Ambiguous session prefix '{session_id}' — matches:", file=sys.stderr)
        for m in matches:
            print(f"  {m.name}", file=sys.stderr)
        sys.exit(1)
    return None


def _fmt_args(name: str, args: dict) -> str:
    if not args:
        return ""
    # Common single-value tools: show the value directly
    for key in ("path", "command", "pattern", "query", "prompt", "intent"):
        if key in args and len(args) == 1:
            return str(args[key])
    # task/subagent: show task name + agent type
    if name == "task":
        parts = []
        if args.get("name"):
            parts.append(args["name"])
        if args.get("agent_type"):
            parts.append(f"[{args['agent_type']}]")
        if args.get("mode") and args.get("mode") != "sync":
            parts.append(f"({args['mode']})")
        return " ".join(parts)
    return json.dumps(args, ensure_ascii=False)


def parse_turn_filter(spec: str) -> set[int]:
    result = set()
    for part in spec.split(","):
        part = part.strip()
        if "-" in part:
            lo, hi = part.split("-", 1)
            result.update(range(int(lo), int(hi) + 1))
        else:
            result.add(int(part))
    return result


def format_turn_range(turn_filter: set[int]) -> str:
    return ", ".join(
        f"{min(g)}-{max(g)}" if len(g) > 1 else str(min(g))
        for g in [sorted(turn_filter)]
    )


def render_transcript(transcript: list[dict], turn_filter: Optional[set] = None) -> None:
    TW = 72
    pending_calls: dict[str, dict] = {}  # call_id -> item, for attaching results

    for item in transcript:
        if turn_filter is not None and item.get("turn") not in turn_filter:
            continue
        kind = item["kind"]

        if kind == "user":
            print()
            print("═" * TW)
            print(f"  TURN {item['turn']}  {format_hhmm(item['ts'])}")
            print("═" * TW)
            print(item["text"])

        elif kind == "thinking":
            print()
            print(ruled("┄ thinking ", "┄", TW))
            print(item["text"])

        elif kind == "assistant":
            print()
            print(ruled("┄ assistant ", "┄", TW))
            print(item["text"])

        elif kind == "tool_call":
            name = item["name"]
            args = item["args"]
            call_id = item["call_id"]
            pending_calls[call_id] = item

            print()
            if name == "task":
                label = f"┄ subagent: {args.get('name', '?')} [{args.get('agent_type', '?')}/{args.get('mode', 'sync')}] "
                print(ruled(label, "┄", TW))
                prompt = args.get("prompt", "")
                if prompt:
                    print(prompt)
            else:
                print(ruled(f"┄ {name} ", "┄", TW))
                arg_str = _fmt_args(name, args)
                if arg_str:
                    print(arg_str)

        elif kind == "tool_result":
            call_id = item["call_id"]
            content = item["content"] or ""
            success = item["success"]
            name = item["name"]
            call = pending_calls.pop(call_id, None)
            is_subagent = call is not None and call.get("name") == "task"
            limit = 3000 if is_subagent else 1200

            flag = " [ERROR]" if not success else ""
            print(f"→ {name}{flag}")
            if len(content) > limit:
                print(content[:limit])
                print(f"  … ({len(content) - limit:,} more chars)")
            else:
                print(content)
            print()


def cmd_detail(session_id: str, raw: bool = False, turn_filter: Optional[set] = None) -> None:
    session_dir = resolve_session_dir(session_id)
    if session_dir is None:
        print(f"Session not found: {session_id}", file=sys.stderr)
        sys.exit(1)

    d = parse_session_detail(session_dir)
    if d is None:
        print(f"Could not parse session: {session_id}", file=sys.stderr)
        sys.exit(1)

    home = str(Path.home())
    cwd = d.get("cwd", "")
    cwd_display = cwd.replace(home, "~") if cwd else "(unknown)"

    print(f"Session:   {d['id']}")
    print(f"Started:   {format_time(d['start_time'])}")
    print(f"Ended:     {format_time(d['end_time'])}")
    print(f"Duration:  {format_duration(d['duration'])}")
    print(f"Directory: {cwd_display}{' (@)' if cwd else ''}")
    if d["git_branch"]:
        print(f"Branch:    {d['git_branch']}")
    if d.get("model"):
        model_str = d["model"]
        effort = d.get("reasoning_effort")
        if effort:
            model_str += f" ({effort})"
        print(f"Model:     {model_str}")
    print()
    print(f"Turns:           {d['user_turn_count']}")
    print(f"Assistant turns: {d['assistant_turn_count']}")
    print(f"Tool calls:      {sum(d['tool_calls'].values())}")
    if d["subagents"]:
        print(f"Sub-agents:      {len(d['subagents'])}")
    print(f"Total events:    {d['total_events']}")

    # Tokens
    mm = d.get("model_metrics")
    if mm:
        section("Tokens")
        col_w = max(len(m) for m in mm) + 2
        header = f"{'Model':<{col_w}}  {'Input':>10}  {'Output':>8}  {'Cache Read':>12}"
        print(header)
        print("-" * len(header))
        for model, data in mm.items():
            u = data.get("usage", {})
            inp = u.get("inputTokens", 0)
            out = u.get("outputTokens", 0)
            cr  = u.get("cacheReadTokens", 0)
            print(f"{model:<{col_w}}  {inp:>10,}  {out:>8,}  {cr:>12,}")

    # Tool usage
    tc = d.get("tool_calls", {})
    if tc:
        section("Tool usage")
        name_w = max(len(n) for n in tc) + 2
        print(f"{'Tool':<{name_w}}  {'Calls':>6}  {'Errors':>6}")
        print("-" * (name_w + 16))
        for name in sorted(tc, key=lambda n: -tc[n]):
            errs = d["tool_errors"].get(name, 0)
            err_str = str(errs) if errs else "-"
            print(f"{name:<{name_w}}  {tc[name]:>6}  {err_str:>6}")

    # Sub-agents
    agents = d.get("subagents", [])
    if agents:
        section(f"Sub-agents ({len(agents)})")
        num_w = len(str(len(agents)))
        name_w = min(max((len(a["task_name"] or a["agent_type"]) for a in agents), default=4) + 1, 16)
        type_w = max(len(a["agent_type"]) for a in agents) + 4  # +2 for space + symbol
        fixed_cols = num_w + 2 + name_w + 2 + 8 + 2 + type_w + 2
        prompt_w = max(30, W - fixed_cols)
        print(f"{'#':>{num_w}}  {'Name':<{name_w}}  {'Time':>8}  {'Type':<{type_w}}  Prompt")
        print("-" * (fixed_cols + prompt_w))
        for i, a in enumerate(agents, 1):
            raw_name = a["task_name"] or a["agent_type"]
            label = (raw_name[:name_w - 1] + "…") if len(raw_name) >= name_w else raw_name
            atype = a["agent_type"]
            type_str = f"{atype} ○" if a["mode"] == "background" else f"{atype} •"
            wall  = format_duration(timedelta(milliseconds=a["wall_ms"])) if a["wall_ms"] else "?"
            prompt_text = a["prompt"].replace("\n", " ")
            if cwd:
                prompt_text = prompt_text.replace(cwd + "/", "@/").replace(cwd, "@")
            prompt_preview = truncate(prompt_text, prompt_w)
            print(f"{i:>{num_w}}  {label:<{name_w}}  {wall:>8}  {type_str:<{type_w}}  {prompt_preview}")

    # Code changes
    cc = d.get("code_changes")
    if cc and (cc.get("linesAdded") or cc.get("linesRemoved") or cc.get("filesModified")):
        section("Code changes")
        added = cc.get("linesAdded", 0)
        removed = cc.get("linesRemoved", 0)
        files = cc.get("filesModified", [])
        print(f"+{added} / -{removed} lines across {len(files)} file(s)")
        for f in files:
            print(f.replace(cwd + "/", "@/").replace(cwd, "@").replace(home, "~"))

    # Build per-turn sub-agent mode index
    agents_by_turn: defaultdict[int, list[str]] = defaultdict(list)
    for a in d.get("subagents", []):
        if a.get("turn") is not None:
            agents_by_turn[a["turn"]].append(a["mode"])

    # Turns
    turns = d["turns"]
    if turns:
        section(f"Turns ({len(turns)})")
        num_w = len(str(len(turns)))
        prefix_w = num_w + 2 + 5 + 2 + 8 + 2 + 1 + 2  # adds marker column (1 char + 2 spaces)
        msg_w = max(20, W - prefix_w)
        print(f"{'#':>{num_w}}  {'Start':<5}  {'Time':>8}     Message")
        print(f"{'-'*num_w}  {'-'*5}  {'-'*8}  {'-':1}  {'-'*msg_w}")
        for i, turn in enumerate(turns, 1):
            ts = format_hhmm(turn["ts"])
            resp = format_duration(timedelta(milliseconds=turn["resp_ms"])) if turn["resp_ms"] else "?"
            modes = agents_by_turn.get(i, [])
            marker = "●" if "sync" in modes else ("○" if modes else " ")
            msg = truncate(turn["text"], msg_w)
            print(f"{i:>{num_w}}  {ts:<5}  {resp:>8}  {marker}  {msg}")

    # Full transcript
    if raw:
        if turn_filter:
            section(f"Transcript  (turns {format_turn_range(turn_filter)})")
        else:
            section("Transcript")
        render_transcript(d["transcript"], turn_filter=turn_filter)


def load_all_sessions() -> list:
    if not DATA_DIR.exists():
        print(f"Session directory not found: {DATA_DIR}", file=sys.stderr)
        sys.exit(1)
    sessions = []
    for entry in DATA_DIR.iterdir():
        if not entry.is_dir():
            continue
        info = parse_session_summary(entry)
        if info:
            sessions.append(info)
    return sessions


def cmd_list(count: int, dir_filter: Optional[str]) -> None:
    # Normalize filter to resolved absolute path
    filter_path = str(Path(dir_filter).expanduser().resolve()) if dir_filter else None

    sessions = [s for s in load_all_sessions()
                if not filter_path or s["cwd"].startswith(filter_path)]
    sessions.sort(key=lambda s: s["start_time"], reverse=True)
    sessions = sessions[:count]

    if not sessions:
        msg = "No sessions found."
        if filter_path:
            msg += f" (filter: {filter_path})"
        print(msg)
        return

    home = str(Path.home())
    dir_display = (filter_path or str(Path.cwd())).replace(home, "~")
    print(f"Directory: {dir_display}")
    print()

    id_w, time_w, turns_w = 8, 16, 5
    fixed_w = id_w + 2 + time_w + 2 + turns_w + 2
    prompt_w = max(20, W - fixed_w)
    print(f"{'Session':>{id_w}}  {'Started':<{time_w}}  {'Turns':>{turns_w}}  First prompt")
    print("-" * (fixed_w + prompt_w))

    for s in sessions:
        short_id = s["id"][:8]
        started = format_time(s["start_time"])
        prompt = truncate(s["first_prompt"], prompt_w)
        print(f"{short_id:>{id_w}}  {started:<{time_w}}  {s['turn_count']:>{turns_w}}  {prompt}")


def cmd_dirs(count: int) -> None:
    sessions = load_all_sessions()
    home = str(Path.home())
    tally: Counter = Counter()
    latest: dict[str, str] = {}
    for s in sessions:
        cwd = s["cwd"] or "(unknown)"
        tally[cwd] += 1
        if cwd not in latest or s["start_time"] > latest[cwd]:
            latest[cwd] = s["start_time"]

    dirs = sorted(tally.keys(), key=lambda d: latest[d], reverse=True)[:count]

    if not dirs:
        print("No sessions found.")
        return

    n_w = max(max(len(str(tally[d])) for d in dirs), len("Sessions"))
    print(f"{'Sessions':>{n_w}}  {'Last session':<16}  Directory")
    print("-" * (n_w + 2 + 16 + 2 + 60))
    for d in dirs:
        n = tally[d]
        last = format_time(latest[d])
        display = d.replace(home, "~")
        print(f"{n:>{n_w}}  {last:<16}  {display}")


def main():
    parser = argparse.ArgumentParser(
        description="List and inspect Copilot sessions.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            "  copilot-sessions                      List sessions in current directory\n"
            "  copilot-sessions --list-dirs          List all project directories with sessions\n"
            "  copilot-sessions -d ~/Projects/myapp  Filter by a specific directory\n"
            "  copilot-sessions f9d6ffdd             Show detail for a session\n"
            "  copilot-sessions f9d6ffdd --raw       Full transcript with reasoning\n"
        ),
    )
    parser.add_argument("session_id", nargs="?", help="Session ID (full or prefix) to inspect")
    parser.add_argument("-n", "--count", type=int, default=DEFAULT_COUNT, metavar="N",
                        help=f"Number of sessions to list (default: {DEFAULT_COUNT})")
    parser.add_argument("-d", "--dir", metavar="DIR",
                        help="Filter sessions by working directory (default: current directory)")
    parser.add_argument("--list-dirs", action="store_true",
                        help="List all project directories with sessions")
    parser.add_argument("--raw", action="store_true",
                        help="Show full transcript with reasoning (use with a session ID)")
    parser.add_argument("--turn", metavar="RANGE",
                        help="Filter transcript to specific turns, e.g. 4 or 4-10 or 4,7-10 (implies --raw)")

    args = parser.parse_args()

    if args.session_id:
        turn_filter = parse_turn_filter(args.turn) if args.turn else None
        cmd_detail(args.session_id, raw=args.raw or turn_filter is not None,
                   turn_filter=turn_filter)
    elif args.list_dirs:
        cmd_dirs(args.count)
    else:
        dir_filter = args.dir if args.dir else str(Path.cwd())
        cmd_list(args.count, dir_filter)


if __name__ == "__main__":
    main()
