#!/usr/bin/env python3
"""List and inspect opencode sessions.

Usage:
  opencode-sessions                                   List sessions in current directory
  opencode-sessions --list-dirs                       List all project directories with sessions
  opencode-sessions -d ~/Projects/myapp               Filter by a specific directory
  opencode-sessions <session-id>              Session summary (tokens, tools, turns)
  opencode-sessions <session-id> --raw        Full transcript with reasoning and tool I/O
  opencode-sessions <session-id> --turn 4     Transcript for a single turn (implies --raw)
  opencode-sessions <session-id> --turn 4-10  Transcript for a range of turns

Session IDs use the `ses_1f46c7e8` format. Accepts a prefix (8+ chars) or full ID.
Data is stored in ~/.local/share/opencode/opencode.db (XDG_DATA_HOME on Linux/macOS).
"""

import argparse
import json
import re
import sqlite3
import sys
from collections import Counter
from datetime import datetime, timedelta, timezone
from pathlib import Path
from typing import Optional

DATA_DIR = Path.home() / ".local" / "share" / "opencode"
DB_PATH = DATA_DIR / "opencode.db"
DEFAULT_COUNT = 30
W = 120

IGNORE_PROMPTS = (
    re.compile(r"^/(clear|new)\s*", re.I),
    re.compile(r"^/(model|help|usage|exit|quit|context|status)\b.*", re.I | re.DOTALL),
)


def _filter_prompt(text: str) -> Optional[str]:
    for pattern in IGNORE_PROMPTS:
        text = pattern.sub("", text, count=1).strip()
    return text or None


def truncate(text: str, width: int) -> str:
    text = text.replace("\n", " ").strip()
    if len(text) <= width:
        return text
    suffix = f" ...({len(text)} chars)"
    return text[: width - len(suffix)] + suffix


def parse_ts(ms: int) -> datetime:
    return datetime.fromtimestamp(ms / 1000, tz=timezone.utc)


def format_time(ms: int) -> str:
    try:
        return parse_ts(ms).astimezone().strftime("%Y-%m-%d %H:%M")
    except Exception:
        return str(ms)[:16]


def format_hhmm(ms: int) -> str:
    try:
        return parse_ts(ms).astimezone().strftime("%H:%M")
    except Exception:
        return "??:??"


def format_duration(td: timedelta) -> str:
    td = timedelta(seconds=round(td.total_seconds()))
    return str(td).removeprefix("0:")


def format_separator(label: str, char: str = "-", width: int = W) -> str:
    return label + char * max(0, width - len(label))


def format_dir(path: str) -> str:
    return path.replace(str(Path.home()), "~") if path else "-"


def format_usd(v: float) -> str:
    return f"${v:.4f}" if v else "-"


def format_any(v: object) -> str:
    if v is None:
        return "?"
    if isinstance(v, timedelta):
        return format_duration(v)
    if isinstance(v, int):
        return f"{v:,}"
    if isinstance(v, float):
        return f"{v:.4f}"
    s = str(v)
    return s if s != "-" else ""


def print_section(title: str) -> None:
    print(f"\n\n=== {title} ===\n")


def print_properties(props: list[tuple[str, str]]) -> None:
    key_w = max(len(k) for k, _ in props) + 2
    for key, val in props:
        print(f"{key:<{key_w}}{val}")


def print_table(rows: list[list[object]]) -> None:
    ncols = len(rows[0])
    row_strs = [[format_any(c) for c in r] for r in rows]
    col_data = [[r[c] for r in rows[1:]] for c in range(ncols)]
    aligns = [">" if data and all(_is_num(v) for v in data) else "<" for data in col_data]
    widths = [max(len(s[c]) for s in row_strs) for c in range(ncols)]
    total = sum(widths) + 2 * (ncols - 1)
    if total > W:
        widths[-1] = max(1, widths[-1] - (total - W))
    for i, r in enumerate(row_strs):
        cells = [f"{truncate(s, widths[c]):{aligns[c]}{widths[c]}}" for c, s in enumerate(r)]
        print("  ".join(cells))
        if i == 0:
            print("-" * (sum(widths) + 2 * (ncols - 1)))


def _is_num(v: object) -> bool:
    if v is None:
        return True
    if isinstance(v, (int, float, timedelta)):
        return True
    return isinstance(v, str) and bool(v) and v[0] == "$"


def _fmt_args(name: str, args: dict) -> str:
    if not args:
        return ""
    for key in ("path", "filePath", "command", "pattern", "query", "prompt", "intent", "description"):
        if key in args and len(args) == 1:
            return str(args[key])
    return json.dumps(args, ensure_ascii=False)


def get_conn() -> sqlite3.Connection:
    if not DB_PATH.exists():
        print(f"Database not found: {DB_PATH}", file=sys.stderr)
        print("Opencode stores session data in XDG_DATA_HOME/opencode/opencode.db", file=sys.stderr)
        sys.exit(1)
    conn = sqlite3.connect(str(DB_PATH))
    conn.row_factory = sqlite3.Row
    return conn


def resolve_session(conn: sqlite3.Connection, session_id: str) -> str:
    """Resolve a partial session ID or slug to a full session ID."""
    rows = conn.execute("""
        SELECT id, slug FROM session
        WHERE id = ? OR id LIKE ? OR slug LIKE ?
        ORDER BY time_created DESC
    """, (session_id, f"{session_id}%", f"{session_id}%")).fetchall()
    if len(rows) == 0:
        print(f"Session not found: {session_id}", file=sys.stderr)
        sys.exit(1)
    if len(rows) > 1:
        disambig = [r["slug"] or r["id"] for r in rows]
        # If one is an exact slug match, use it
        exact = [r for r in rows if r["slug"] == session_id]
        if len(exact) == 1:
            return exact[0]["id"]
        print(f"Ambiguous session '{session_id}' — matches:", file=sys.stderr)
        for r in rows:
            label = r["slug"] or r["id"]
            print(f"  {label}", file=sys.stderr)
        sys.exit(1)
    return rows[0]["id"]


def load_all_summaries(conn: sqlite3.Connection) -> list[dict]:
    rows = conn.execute("""
        SELECT s.id, s.slug, s.directory, s.title, s.time_created, s.time_updated, s.agent
        FROM session s ORDER BY s.time_created DESC
    """).fetchall()

    summaries = []
    for r in rows:
        # Count user turns and get first prompt
        turn_row = conn.execute("""
            SELECT COUNT(*) as cnt FROM message m
            WHERE m.session_id = ? AND json_extract(m.data, '$.role') = 'user'
        """, (r["id"],)).fetchone()
        turn_count = turn_row["cnt"] if turn_row else 0

        first_text = None
        if turn_count > 0:
            fp_row = conn.execute("""
                SELECT p.data as pd FROM message m
                JOIN part p ON p.message_id = m.id
                WHERE m.session_id = ? AND json_extract(m.data, '$.role') = 'user'
                  AND json_extract(p.data, '$.type') = 'text'
                ORDER BY m.time_created, p.time_created LIMIT 1
            """, (r["id"],)).fetchone()
            if fp_row:
                pd = json.loads(fp_row["pd"])
                raw = pd.get("text", "")
                filtered = _filter_prompt(raw.strip()) if raw.strip() else None
                first_text = filtered or raw[:80]

        summaries.append({
            "id": r["id"],
            "slug": r["slug"] or "",
            "start_time": r["time_created"],
            "end_time": r["time_updated"],
            "cwd": r["directory"] or "",
            "first_prompt": first_text or "(no prompt found)",
            "turn_count": turn_count,
        })
    return summaries


def parse_session_detail(conn: sqlite3.Connection, session_id: str) -> Optional[dict]:
    srow = conn.execute("""
        SELECT id, slug, directory, title, time_created, time_updated, agent, model
        FROM session WHERE id = ?
    """, (session_id,)).fetchone()
    if not srow:
        return None

    model_field = json.loads(srow["model"]) if srow["model"] else {}
    model_id = model_field.get("id", "") if isinstance(model_field, dict) else ""
    start_time = srow["time_created"]
    end_time = srow["time_updated"]
    duration = timedelta(milliseconds=end_time - start_time) if end_time > start_time else timedelta(0)
    cwd = srow["directory"] or ""

    msg_rows = conn.execute("""
        SELECT m.id as mid, m.time_created as mtime, m.data as mdata
        FROM message m WHERE m.session_id = ?
        ORDER BY m.time_created, m.id
    """, (session_id,)).fetchall()

    tool_calls: dict[str, int] = {}
    tool_errors: dict[str, int] = {}
    user_messages: list[dict] = []
    transcript: list[dict] = []
    current_turn = 0
    usage_by_model: dict[str, dict[str, int | float]] = {}
    turn_response_ms: dict[int, int] = {}

    for mr in msg_rows:
        mdata = json.loads(mr["mdata"])
        role = mdata.get("role", "")
        mtime = mr["mtime"]

        part_rows = conn.execute("""
            SELECT data FROM part WHERE message_id = ? ORDER BY time_created, id
        """, (mr["mid"],)).fetchall()
        parts = [json.loads(pr["data"]) for pr in part_rows]

        if role == "user":
            user_text = None
            for p in parts:
                if p.get("type") == "text":
                    text = p.get("text", "").strip()
                    if text:
                        user_text = _filter_prompt(text) or text
                    break
            if user_text:
                current_turn += 1
                user_messages.append({"text": user_text, "ts": mtime})
                transcript.append({"kind": "user", "turn": current_turn, "text": user_text, "ts": mtime})

        elif role == "assistant":
            tokens = mdata.get("tokens", {})
            if isinstance(tokens, dict) and tokens:
                mid_key = model_id or "unknown"
                bucket = usage_by_model.setdefault(mid_key, {"cost": 0.0})
                for k in ("input", "output", "reasoning", "total"):
                    v = tokens.get(k, 0)
                    if isinstance(v, (int, float)):
                        bucket[k] = bucket.get(k, 0) + int(v)
                cache = tokens.get("cache", {})
                if isinstance(cache, dict):
                    cr = cache.get("read", 0)
                    cw = cache.get("write", 0)
                    bucket["cache_read"] = bucket.get("cache_read", 0) + int(cr)
                    bucket["cache_write"] = bucket.get("cache_write", 0) + int(cw)

            cost = mdata.get("cost", 0)
            if isinstance(cost, (int, float)):
                mid_key = model_id or "unknown"
                usage_by_model.setdefault(mid_key, {})["cost"] = usage_by_model[mid_key].get("cost", 0) + cost

            # Sum actual agent response time (not wall-clock gap between prompts)
            msg_time = mdata.get("time")
            if isinstance(msg_time, dict):
                t_create = msg_time.get("created")
                t_comp = msg_time.get("completed")
                if t_create and t_comp:
                    turn_response_ms[current_turn] = turn_response_ms.get(current_turn, 0) + (t_comp - t_create)

            for p in parts:
                ptype = p.get("type", "")
                if ptype == "reasoning":
                    text = p.get("text", "").strip()
                    if text:
                        transcript.append({"kind": "thinking", "turn": current_turn, "text": text})
                elif ptype == "tool":
                    tool_name = p.get("tool", "?")
                    call_id = p.get("callID", "")
                    state = p.get("state", {})
                    inp = state.get("input", {})
                    out = state.get("output", "")
                    status = state.get("status", "")
                    is_error = status == "error"
                    tool_calls[tool_name] = tool_calls.get(tool_name, 0) + 1
                    if is_error:
                        tool_errors[tool_name] = tool_errors.get(tool_name, 0) + 1
                    transcript.append({
                        "kind": "tool_call", "turn": current_turn,
                        "name": tool_name, "args": inp, "call_id": call_id,
                    })
                    transcript.append({
                        "kind": "tool_result", "turn": current_turn,
                        "call_id": call_id, "name": tool_name,
                        "content": out, "success": not is_error,
                    })

    turns = []
    for i, m in enumerate(user_messages):
        resp_ms = turn_response_ms.get(i + 1)
        turns.append({"text": m["text"], "ts": m["ts"], "resp_ms": resp_ms})

    return {
        "id": srow["id"],
        "slug": srow["slug"] or "",
        "title": srow["title"] or "",
        "start_time": start_time,
        "end_time": end_time,
        "duration": duration,
        "cwd": cwd,
        "agent": srow["agent"] or "",
        "model_id": model_id,
        "turns": turns,
        "user_turn_count": len(turns),
        "tool_calls": tool_calls,
        "tool_errors": tool_errors,
        "usage_by_model": usage_by_model,
        "transcript": transcript,
    }


def cmd_dirs(count: int) -> None:
    conn = get_conn()
    rows = conn.execute("SELECT directory FROM session").fetchall()
    conn.close()

    home = str(Path.home())
    tally: Counter = Counter()
    for r in rows:
        tally[r["directory"] or "(unknown)"] += 1
    if not tally:
        print("No sessions found.")
        return
    dirs = sorted(tally.keys(), key=lambda d: tally[d], reverse=True)[:count]
    print_table([["Sessions", "Directory"]] + [
        [tally[d], d.replace(home, "~")] for d in dirs
    ])


def cmd_list(count: int, dir_filter: Optional[str]) -> None:
    filter_path = str(Path(dir_filter).expanduser().resolve()) if dir_filter else None
    conn = get_conn()
    summaries = load_all_summaries(conn)
    conn.close()

    if filter_path:
        summaries = [s for s in summaries if s["cwd"].startswith(filter_path)]
    summaries.sort(key=lambda s: s["start_time"], reverse=True)
    summaries = summaries[:count]

    if not summaries:
        msg = "No sessions found."
        if filter_path:
            msg += f" (filter: {filter_path})"
        print(msg)
        return

    home = str(Path.home())
    dir_display = (filter_path or str(Path.cwd())).replace(home, "~")
    print(f"Directory: {dir_display}\n")

    print_table([["Session", "Started", "Turns", "First prompt"]] + [
        [s["id"][:12], format_time(s["start_time"]), s["turn_count"], s["first_prompt"]]
        for s in summaries
    ])


def parse_turn_filter(spec: str) -> set[int]:
    result = set()
    for part in spec.split(","):
        part = part.strip()
        if "-" in part:
            lo, hi = part.split("-", 1)
            result.update(range(int(lo), int(hi) + 1))
        else:
            result.add(int(part))
    return result


def format_turn_range(turn_filter: set[int]) -> str:
    return ", ".join(
        f"{min(g)}-{max(g)}" if len(g) > 1 else str(min(g))
        for g in [sorted(turn_filter)]
    )


def render_transcript(transcript: list[dict], turn_filter: Optional[set] = None) -> None:
    TW = 72
    pending_calls: dict[str, dict] = {}

    for item in transcript:
        if turn_filter is not None and item.get("turn") not in turn_filter:
            continue
        kind = item["kind"]

        if kind == "user":
            print()
            print("═" * TW)
            print(f"  TURN {item['turn']}  {format_hhmm(item['ts'])}")
            print("═" * TW)
            print(item["text"])

        elif kind == "thinking":
            print()
            print(format_separator("┄ thinking ", "┄", TW))
            print(item["text"])

        elif kind == "tool_call":
            name = item["name"]
            args = item["args"]
            call_id = item["call_id"]
            pending_calls[call_id] = item
            print()
            print(format_separator(f"┄ {name} ", "┄", TW))
            arg_str = _fmt_args(name, args)
            if arg_str:
                print(arg_str)

        elif kind == "tool_result":
            call_id = item["call_id"]
            content = item["content"] or ""
            success = item["success"]
            name = item["name"]
            call = pending_calls.pop(call_id, None)
            limit = 1200
            flag = " [ERROR]" if not success else ""
            print(f"→ {name}{flag}")
            if len(content) > limit:
                print(content[:limit])
                print(f"  … ({len(content) - limit:,} more chars)")
            else:
                print(content)
            print()


def cmd_detail(session_id: str, raw: bool = False, turn_filter: Optional[set] = None) -> None:
    conn = get_conn()
    full_id = resolve_session(conn, session_id)

    d = parse_session_detail(conn, full_id)
    conn.close()
    if d is None:
        print(f"Could not parse session: {session_id}", file=sys.stderr)
        sys.exit(1)

    cwd = d.get("cwd", "")

    print_properties([
        ("Session:", d["id"]),
        ("Title:", d.get("title") or "-"),
        ("Started:", format_time(d["start_time"])),
        ("Ended:", format_time(d["end_time"]) if d.get("end_time") else "-"),
        ("Duration:", format_duration(d["duration"])),
        ("Directory:", format_dir(cwd)),
        ("Agent:", d.get("agent") or "-"),
        ("Model:", d.get("model_id") or "-"),
        ("Turns:", str(d["user_turn_count"])),
        ("Tool calls:", str(sum(d["tool_calls"].values()))),
    ])

    ubm = d["usage_by_model"]
    if ubm:
        print_section("Tokens")
        print_table([
            ["Model", "Input", "Output", "Cached", "Cost"]
        ] + [
            [m, u.get("input", 0), u.get("output", 0), u.get("cache_read", 0), format_usd(u.get("cost"))]
            for m, u in ubm.items()
        ])

    tc = d["tool_calls"]
    if tc:
        print_section("Tool usage")
        print_table([
            ["Tool Name", "Calls", "Errors"]
        ] + [
            [name, tc[name], d["tool_errors"].get(name, 0) or ""]
            for name in sorted(tc, key=lambda n: -tc[n])
        ])

    turns = d["turns"]
    if turns:
        print_section(f"Turns ({len(turns)})")
        print_table([["#", "Start", "Time", "Message"]] + [
            [i, format_hhmm(t["ts"]),
             timedelta(milliseconds=t["resp_ms"]) if t["resp_ms"] else None,
             t["text"]]
            for i, t in enumerate(turns, 1)
        ])

    if raw:
        if turn_filter:
            print_section(f"Transcript  (turns {format_turn_range(turn_filter)})")
        else:
            print_section("Transcript")
        render_transcript(d["transcript"], turn_filter=turn_filter)


def main():
    parser = argparse.ArgumentParser(
        description="List and inspect opencode sessions.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            "  opencode-sessions                        List sessions in current directory\n"
            "  opencode-sessions --list-dirs            List all project directories with sessions\n"
            "  opencode-sessions -d ~/Projects/myapp    Filter by a specific directory\n"
            "  opencode-sessions jolly-ha               Show detail for a session (slug prefix)\n"
            "  opencode-sessions jolly-ha --raw         Full transcript with reasoning\n"
        ),
    )
    parser.add_argument("session_id", nargs="?", help="Session ID (prefix or full, e.g. ses_1f46c7e8)")
    parser.add_argument("-n", "--count", type=int, default=DEFAULT_COUNT, metavar="N",
                        help=f"Number of sessions to list (default: {DEFAULT_COUNT})")
    parser.add_argument("-d", "--dir", metavar="DIR",
                        help="Filter sessions by working directory (default: current directory)")
    parser.add_argument("--list-dirs", action="store_true",
                        help="List all project directories with sessions")
    parser.add_argument("--raw", action="store_true",
                        help="Show full transcript with reasoning (use with a session ID)")
    parser.add_argument("--turn", metavar="RANGE",
                        help="Filter transcript to specific turns, e.g. 4 or 4-10 or 4,7-10 (implies --raw)")

    args = parser.parse_args()

    if args.session_id:
        turn_filter = parse_turn_filter(args.turn) if args.turn else None
        cmd_detail(args.session_id, raw=args.raw or turn_filter is not None,
                   turn_filter=turn_filter)
    elif args.list_dirs:
        cmd_dirs(args.count)
    else:
        dir_filter = args.dir if args.dir else str(Path.cwd())
        cmd_list(args.count, dir_filter)


if __name__ == "__main__":
    main()
