#!/usr/bin/env python3
"""List and inspect Mistral Vibe sessions.

Usage:
  vibe-sessions                           List sessions in current directory
  vibe-sessions --list-dirs               List all project directories with sessions
  vibe-sessions -d ~/Projects/myapp       Filter by a specific directory
  vibe-sessions <session-id>              Session summary (id, tokens, tools, turns)
  vibe-sessions <session-id> --raw        Full transcript with tool I/O
  vibe-sessions <session-id> --turn 4     Transcript for a single turn (implies --raw)
  vibe-sessions <session-id> --turn 4-10  Transcript for a range of turns

Session IDs can be given as a full UUID, an 8-char prefix, or a path to a session directory.
"""

import argparse
import json
import re
import sys
from collections import Counter
from datetime import datetime, timedelta
from pathlib import Path
from typing import Optional

DATA_DIR = Path.home() / ".vibe" / "logs" / "session"
DEFAULT_COUNT = 30
MAX_PROMPT_WIDTH = 80
W = 120

IGNORE_PROMPTS = (
    re.compile(r"^/(clear|new)\s*", re.I),
    re.compile(r"^/(model|help|usage|exit|quit|context|status)\b.*", re.I | re.DOTALL),
)


def _filter_prompt(text: str) -> Optional[str]:
    for pattern in IGNORE_PROMPTS:
        text = pattern.sub("", text, count=1).strip()
    return text or None


def truncate(text: str, width: int) -> str:
    text = text.replace("\n", " ").strip()
    if len(text) <= width:
        return text
    suffix = f" ...({len(text)} chars)"
    return text[: width - len(suffix)] + suffix


def parse_iso(ts: str) -> datetime:
    return datetime.fromisoformat(ts.replace("Z", "+00:00"))


def format_time(ts: str) -> str:
    try:
        return parse_iso(ts).astimezone().strftime("%Y-%m-%d %H:%M")
    except Exception:
        return ts[:16]


def format_hhmm(ts: str) -> str:
    try:
        return parse_iso(ts).astimezone().strftime("%H:%M")
    except Exception:
        return ts[11:16]


def format_duration(td: timedelta) -> str:
    total = int(td.total_seconds())
    h, rem = divmod(total, 3600)
    m, s = divmod(rem, 60)
    if h:
        return f"{h}h {m}m"
    if m:
        return f"{m}m {s}s"
    return f"{s}s"


def load_meta(session_dir: Path) -> Optional[dict]:
    try:
        with (session_dir / "meta.json").open(encoding="utf-8") as f:
            return json.load(f)
    except (OSError, json.JSONDecodeError):
        return None


def load_messages(session_dir: Path) -> Optional[list]:
    path = session_dir / "messages.jsonl"
    if not path.exists():
        return None
    messages = []
    try:
        with path.open(encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    messages.append(json.loads(line))
                except json.JSONDecodeError:
                    continue
    except OSError:
        return None
    return messages


def session_hex(session_dir: Path) -> str:
    """Extract 8-char hex from dirname like session_YYYYMMDD_HHMMSS_8hex."""
    parts = session_dir.name.split("_")
    return parts[-1] if len(parts) >= 4 else session_dir.name


def parse_session_summary(session_dir: Path) -> Optional[dict]:
    meta = load_meta(session_dir)
    if not meta:
        return None
    start_time = meta.get("start_time")
    if not start_time:
        return None

    cwd = meta.get("environment", {}).get("working_directory", "")
    session_id = meta.get("session_id", session_hex(session_dir))

    messages = load_messages(session_dir) or []
    first_prompt = None
    turn_count = 0
    for msg in messages:
        if msg.get("role") == "user" and not msg.get("injected"):
            content = msg.get("content", "")
            if isinstance(content, str) and content.strip():
                text = _filter_prompt(content.strip())
                if text:
                    turn_count += 1
                    if first_prompt is None:
                        first_prompt = text

    return {
        "id": session_id,
        "path": session_dir,
        "start_time": start_time,
        "end_time": meta.get("end_time"),
        "cwd": cwd,
        "git_branch": meta.get("git_branch", ""),
        "first_prompt": first_prompt or "(no prompt found)",
        "turn_count": turn_count,
    }


def parse_session_detail(session_dir: Path) -> Optional[dict]:
    meta = load_meta(session_dir)
    if not meta:
        return None
    start_time = meta.get("start_time")
    if not start_time:
        return None

    end_time = meta.get("end_time")
    try:
        duration = parse_iso(end_time) - parse_iso(start_time) if end_time else timedelta(0)
    except Exception:
        duration = timedelta(0)

    cwd = meta.get("environment", {}).get("working_directory", "")
    git_branch = meta.get("git_branch", "")
    session_id = meta.get("session_id", session_hex(session_dir))
    stats = meta.get("stats", {})

    # Model: v2 uses agent_profile, v1 used agent_config
    profile = meta.get("agent_profile") or meta.get("agent_config", {})
    model = profile.get("name") or profile.get("active_model", "")

    messages = load_messages(session_dir) or []
    tool_calls: dict[str, int] = {}
    tool_errors: dict[str, int] = {}
    tool_id_to_name: dict[str, str] = {}
    user_messages: list[dict] = []
    transcript: list[dict] = []
    current_turn = 0

    for msg in messages:
        role = msg.get("role", "")

        if role == "user" and not msg.get("injected"):
            content = msg.get("content", "")
            if isinstance(content, str):
                text = _filter_prompt(content.strip()) if content.strip() else None
                if text:
                    current_turn += 1
                    user_messages.append({"text": text})
                    transcript.append({"kind": "user", "turn": current_turn, "text": text})

        elif role == "assistant":
            text = (msg.get("content") or "").strip()
            if text:
                transcript.append({"kind": "assistant", "turn": current_turn, "text": text})
            for tc in msg.get("tool_calls", []):
                fn = tc.get("function", {})
                name = fn.get("name", "?")
                tid = tc.get("id", "")
                try:
                    args = json.loads(fn.get("arguments", "{}"))
                except (json.JSONDecodeError, TypeError):
                    args = {}
                tool_id_to_name[tid] = name
                tool_calls[name] = tool_calls.get(name, 0) + 1
                transcript.append({
                    "kind": "tool_call", "turn": current_turn,
                    "name": name, "args": args, "call_id": tid,
                })

        elif role == "tool":
            name = msg.get("name") or tool_id_to_name.get(msg.get("tool_call_id", ""), "?")
            tid = msg.get("tool_call_id", "")
            content = msg.get("content", "") or ""
            is_error = msg.get("is_error", False)
            if is_error:
                tool_errors[name] = tool_errors.get(name, 0) + 1
            transcript.append({
                "kind": "tool_result", "turn": current_turn,
                "call_id": tid, "name": name,
                "content": content, "success": not is_error,
            })

    return {
        "id": session_id,
        "start_time": start_time,
        "end_time": end_time,
        "duration": duration,
        "cwd": cwd,
        "git_branch": git_branch,
        "model": model,
        "stats": stats,
        "turns": [{"text": m["text"]} for m in user_messages],
        "user_turn_count": len(user_messages),
        "tool_calls": tool_calls,
        "tool_errors": tool_errors,
        "transcript": transcript,
    }


def ruled(label: str, char: str = "-", width: int = W) -> str:
    return label + char * max(0, width - len(label))


def section(title: str) -> None:
    print()
    print(ruled(f"-- {title} "))


def _fmt_args(name: str, args: dict) -> str:
    if not args:
        return ""
    for key in ("path", "command", "pattern", "query", "prompt", "intent"):
        if key in args and len(args) == 1:
            return str(args[key])
    return json.dumps(args, ensure_ascii=False)


def parse_turn_filter(spec: str) -> set[int]:
    result = set()
    for part in spec.split(","):
        part = part.strip()
        if "-" in part:
            lo, hi = part.split("-", 1)
            result.update(range(int(lo), int(hi) + 1))
        else:
            result.add(int(part))
    return result


def format_turn_range(turn_filter: set[int]) -> str:
    return ", ".join(
        f"{min(g)}-{max(g)}" if len(g) > 1 else str(min(g))
        for g in [sorted(turn_filter)]
    )


def render_transcript(transcript: list[dict], turn_filter: Optional[set] = None) -> None:
    TW = 72
    pending_calls: dict[str, dict] = {}

    for item in transcript:
        if turn_filter is not None and item.get("turn") not in turn_filter:
            continue
        kind = item["kind"]

        if kind == "user":
            print()
            print("═" * TW)
            print(f"  TURN {item['turn']}")
            print("═" * TW)
            print(item["text"])

        elif kind == "assistant":
            print()
            print(ruled("┄ assistant ", "┄", TW))
            print(item["text"])

        elif kind == "tool_call":
            name = item["name"]
            call_id = item["call_id"]
            pending_calls[call_id] = item
            print()
            print(ruled(f"┄ {name} ", "┄", TW))
            arg_str = _fmt_args(name, item["args"])
            if arg_str:
                print(arg_str)

        elif kind == "tool_result":
            call_id = item["call_id"]
            content = item["content"] or ""
            success = item["success"]
            name = item["name"]
            pending_calls.pop(call_id, None)
            flag = " [ERROR]" if not success else ""
            print(f"→ {name}{flag}")
            limit = 1200
            if len(content) > limit:
                print(content[:limit])
                print(f"  … ({len(content) - limit:,} more chars)")
            else:
                print(content)
            print()


def iter_session_dirs() -> list[Path]:
    if not DATA_DIR.exists():
        return []
    return [d for d in DATA_DIR.iterdir()
            if d.is_dir() and (d / "meta.json").exists()]


def resolve_session_dir(session_id: str) -> Optional[Path]:
    candidate = Path(session_id).expanduser()
    if candidate.is_dir() and (candidate / "meta.json").exists():
        return candidate

    matches = []
    for d in DATA_DIR.iterdir():
        if not d.is_dir():
            continue
        hex_id = session_hex(d)
        if hex_id == session_id or hex_id.startswith(session_id):
            matches.append(d)

    if not matches:
        # Fall back to UUID prefix match via meta.json
        for d in DATA_DIR.iterdir():
            if not d.is_dir():
                continue
            meta = load_meta(d)
            if meta:
                uid = meta.get("session_id", "")
                if uid == session_id or uid.startswith(session_id):
                    matches.append(d)

    if len(matches) == 1:
        return matches[0]
    if len(matches) > 1:
        print(f"Ambiguous session prefix '{session_id}' — matches:", file=sys.stderr)
        for m in matches:
            print(f"  {session_hex(m)}", file=sys.stderr)
        sys.exit(1)
    return None


def load_all_summaries() -> list[dict]:
    if not DATA_DIR.exists():
        print(f"Vibe session directory not found: {DATA_DIR}", file=sys.stderr)
        sys.exit(1)
    results = []
    for d in iter_session_dirs():
        info = parse_session_summary(d)
        if info:
            results.append(info)
    return results


def cmd_dirs(count: int) -> None:
    all_sessions = load_all_summaries()
    home = str(Path.home())
    tally: Counter = Counter()
    latest: dict[str, str] = {}
    for s in all_sessions:
        cwd = s["cwd"] or "(unknown)"
        tally[cwd] += 1
        if cwd not in latest or s["start_time"] > latest[cwd]:
            latest[cwd] = s["start_time"]

    dirs = sorted(tally.keys(), key=lambda d: latest[d], reverse=True)[:count]
    if not dirs:
        print("No sessions found.")
        return

    n_w = max(max(len(str(tally[d])) for d in dirs), len("Sessions"))
    print(f"{'Sessions':>{n_w}}  {'Last session':<16}  Directory")
    print("-" * (n_w + 2 + 16 + 2 + 60))
    for d in dirs:
        n = tally[d]
        last = format_time(latest[d])
        display = d.replace(home, "~")
        print(f"{n:>{n_w}}  {last:<16}  {display}")


def cmd_list(count: int, dir_filter: Optional[str]) -> None:
    filter_path = str(Path(dir_filter).expanduser().resolve()) if dir_filter else None
    all_sessions = load_all_summaries()
    if filter_path:
        sessions = [s for s in all_sessions if s["cwd"].startswith(filter_path)]
    else:
        sessions = all_sessions
    sessions.sort(key=lambda s: s["start_time"], reverse=True)
    sessions = sessions[:count]

    if not sessions:
        msg = "No sessions found."
        if filter_path:
            msg += f" (filter: {filter_path})"
        print(msg)
        return

    home = str(Path.home())
    dir_display = (filter_path or str(Path.cwd())).replace(home, "~")
    print(f"Directory: {dir_display}")
    print()

    id_w, time_w, turns_w = 8, 16, 5
    fixed_w = id_w + 2 + time_w + 2 + turns_w + 2
    prompt_w = max(20, W - fixed_w)
    print(f"{'Session':>{id_w}}  {'Started':<{time_w}}  {'Turns':>{turns_w}}  First prompt")
    print("-" * (fixed_w + prompt_w))

    for s in sessions:
        short_id = s["id"][:8]
        started = format_time(s["start_time"])
        prompt = truncate(s["first_prompt"], prompt_w)
        print(f"{short_id:>{id_w}}  {started:<{time_w}}  {s['turn_count']:>{turns_w}}  {prompt}")


def cmd_detail(session_id: str, raw: bool = False, turn_filter: Optional[set] = None) -> None:
    session_dir = resolve_session_dir(session_id)
    if session_dir is None:
        print(f"Session not found: {session_id}", file=sys.stderr)
        sys.exit(1)

    d = parse_session_detail(session_dir)
    if d is None:
        print(f"Could not parse session: {session_id}", file=sys.stderr)
        sys.exit(1)

    home = str(Path.home())
    cwd = d.get("cwd", "")
    cwd_display = cwd.replace(home, "~") if cwd else "(unknown)"

    print(f"Session:   {d['id']}")
    print(f"Started:   {format_time(d['start_time'])}")
    if d.get("end_time"):
        print(f"Ended:     {format_time(d['end_time'])}")
    print(f"Duration:  {format_duration(d['duration'])}")
    print(f"Directory: {cwd_display}")
    if d["git_branch"]:
        print(f"Branch:    {d['git_branch']}")
    if d.get("model"):
        print(f"Model:     {d['model']}")
    print()
    print(f"Turns:        {d['user_turn_count']}")
    total_tools = sum(d["tool_calls"].values())
    print(f"Tool calls:   {total_tools}")

    stats = d.get("stats", {})
    inp = stats.get("session_prompt_tokens", 0)
    out = stats.get("session_completion_tokens", 0)
    cost = stats.get("session_cost")
    if inp or out:
        section("Tokens")
        header = f"{'':20}  {'Input':>10}  {'Output':>8}"
        print(header)
        print("-" * len(header))
        print(f"{'Session':<20}  {inp:>10,}  {out:>8,}")
        if cost is not None:
            print(f"\nCost: ${cost:.4f}")

    tc = d["tool_calls"]
    if tc:
        section("Tool usage")
        name_w = max(len(n) for n in tc) + 2
        print(f"{'Tool':<{name_w}}  {'Calls':>6}  {'Errors':>6}")
        print("-" * (name_w + 16))
        for name in sorted(tc, key=lambda n: -tc[n]):
            errs = d["tool_errors"].get(name, 0)
            err_str = str(errs) if errs else "-"
            print(f"{name:<{name_w}}  {tc[name]:>6}  {err_str:>6}")

    turns = d["turns"]
    if turns:
        section(f"Turns ({len(turns)})")
        num_w = len(str(len(turns)))
        msg_w = max(20, W - num_w - 4)
        print(f"{'#':>{num_w}}  Message")
        print(f"{'-'*num_w}  {'-'*msg_w}")
        for i, turn in enumerate(turns, 1):
            msg = truncate(turn["text"], msg_w)
            print(f"{i:>{num_w}}  {msg}")

    if raw:
        if turn_filter:
            section(f"Transcript  (turns {format_turn_range(turn_filter)})")
        else:
            section("Transcript")
        render_transcript(d["transcript"], turn_filter=turn_filter)


def main():
    parser = argparse.ArgumentParser(
        description="List and inspect Mistral Vibe sessions.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            "  vibe-sessions                         List sessions in current directory\n"
            "  vibe-sessions --list-dirs             List all project directories with sessions\n"
            "  vibe-sessions -d ~/Projects/myapp     Filter by a specific directory\n"
            "  vibe-sessions 746bd982                Show detail for a session\n"
            "  vibe-sessions 746bd982 --raw          Full transcript\n"
        ),
    )
    parser.add_argument("session_id", nargs="?", help="Session ID (full UUID, 8-char prefix, or directory path)")
    parser.add_argument("-n", "--count", type=int, default=DEFAULT_COUNT, metavar="N",
                        help=f"Number of sessions/dirs to list (default: {DEFAULT_COUNT})")
    parser.add_argument("-d", "--dir", metavar="DIR",
                        help="Filter sessions by working directory (default: current directory)")
    parser.add_argument("--list-dirs", action="store_true",
                        help="List all project directories with sessions")
    parser.add_argument("--raw", action="store_true",
                        help="Show full transcript with tool I/O (use with a session ID)")
    parser.add_argument("--turn", metavar="RANGE",
                        help="Filter transcript to specific turns, e.g. 4 or 4-10 or 4,7-10 (implies --raw)")

    args = parser.parse_args()

    if args.session_id:
        turn_filter = parse_turn_filter(args.turn) if args.turn else None
        cmd_detail(args.session_id, raw=args.raw or turn_filter is not None,
                   turn_filter=turn_filter)
    elif args.list_dirs:
        cmd_dirs(args.count)
    else:
        dir_filter = args.dir if args.dir else str(Path.cwd())
        cmd_list(args.count, dir_filter)


if __name__ == "__main__":
    main()
